        Node<T>* newNode=new Node<T>(data);
        if(!root) { root=newNode; return; }
        Node<T>* temp=root;
        while(true) {
            if(data<temp->data) {
                if(temp->left) temp=temp->left;
                else { temp->left=newNode; return; }
            } else if(data>temp->data) {
                if(temp->right) temp=temp->right;
